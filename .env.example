# Copy to .env and adjust. .env is gitignored; this file is not.

# --- Postgres (read by docker compose and by the binaries) ---
POSTGRES_USER=chainscope
POSTGRES_PASSWORD=chainscope
POSTGRES_DB=chainscope
# Host port the container is published on. Change if 5432 is already taken.
POSTGRES_PORT=5432

# Connection string used by the indexer and the API.
# Must match the four values above.
DATABASE_URL=postgres://chainscope:chainscope@localhost:5432/chainscope

# --- RPC providers ---
# Comma-separated. Two or three give failover when one starts rate-limiting.
# These carry API keys, which is why they live here and not in chainscope.toml.
CHAINSCOPE_CHAIN__RPC_ENDPOINTS=https://eth.llamarpc.com,https://rpc.ankr.com/eth

# --- Logging ---
# tracing-subscriber env filter, e.g. info, debug, chainscope=debug.
# Overrides log.filter in chainscope.toml.
RUST_LOG=info

# Everything else lives in chainscope.toml. Any value there can be overridden
# from here with CHAINSCOPE_<SECTION>__<KEY>, for example:
#   CHAINSCOPE_PIPELINE__BATCH_SIZE=1000
#   CHAINSCOPE_CHAIN__POOLS=0xaaa...,0xbbb...
